{
    "env": {
        "browser": true,
        "es2021": true
    },
    "extends": [
        "plugin:vue/recommended",
        "standard"
    ],
    "parser": "vue-eslint-parser",
    "parserOptions": {
        "ecmaVersion": 12,
        "sourceType": "module",
        "parser": {
            "js": "espree"
        }
    },
    "rules": {
        "vue/multi-word-component-names": "off",
        "vue/require-default-prop": "off",
        "vue/no-v-html": "warn",
        "no-tabs": "off",
        "no-mixed-spaces-and-tabs": "off"
    }
}
